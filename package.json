{
  "name": "jira-clone-backend",
  "version": "1.0.0",
  "description": "Backend API for a JIRA clone with JWT authentication and MySQL.",
  "main": "src/server.js",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "nodemon src/server.js",
    "debug": "nodemon --inspect=9229 src/server.js",
    "debug:brk": "nodemon --inspect-brk=9229 src/server.js",
    "start": "node src/server.js",
    "migrate:attachments:r2": "node scripts/migrate-attachments-to-r2.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/s3-request-presigner": "^3.1075.0",
    "@langchain/langgraph": "^1.4.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.2.0",
    "mysql2": "^3.12.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
