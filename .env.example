PORT=5001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5001
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=jira_clone

JWT_SECRET=replace_this_with_a_long_random_secret
JWT_EXPIRES_IN=1d

GEMINI_API_KEY=your_personal_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash-lite

GROQ_API_KEY=your_personal_groq_api_key
GROQ_MODEL=openai/gpt-oss-20b

# Use "local" for development or "r2" for deployed object storage.
STORAGE_PROVIDER=local
LOCAL_UPLOAD_ROOT=uploads/tickets
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=taskboard-attachments

LOG_DIR=logs
LOG_TO_CONSOLE=true
LOG_REQUEST_BODY=false
